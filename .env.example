# EmailJS configuration for the contact form.
# 1. Copy this file to ".env"  ->  cp .env.example .env
# 2. Fill in the values below (from https://dashboard.emailjs.com).
# 3. Restart the dev server (npm run dev) so Vite picks up the new values.
#
# The PUBLIC KEY is safe to expose in browser code. Do NOT add any private key.
#
# The form sends TWO emails per submission:
#   - Team notification -> your inbox      (VITE_EMAILJS_TEMPLATE_ID + VITE_EMAILJS_TO_EMAIL)
#   - Customer auto-reply -> the submitter (VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID)

VITE_EMAILJS_SERVICE_ID=paste_your_service_id_here
VITE_EMAILJS_PUBLIC_KEY=paste_your_public_key_here

# Team-notification template. Set its "To Email" field to {{to_email}}.
VITE_EMAILJS_TEMPLATE_ID=paste_your_notification_template_id_here
VITE_EMAILJS_TO_EMAIL=you@yourcompany.com

# Customer auto-reply template. Set its "To Email" field to {{email}}.
VITE_EMAILJS_AUTOREPLY_TEMPLATE_ID=paste_your_autoreply_template_id_here
